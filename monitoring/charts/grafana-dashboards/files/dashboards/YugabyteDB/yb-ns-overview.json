{
  "uid": "yb-ns-overview",
  "title": "YugabyteDB · Namespace Overview (Direct / Higher Env)",
  "tags": [
    "yugabytedb",
    "namespace",
    "higher-env"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "",
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "label": "Data source",
        "query": "prometheus",
        "refresh": 1,
        "hide": 0,
        "current": {},
        "regex": "",
        "multi": false,
        "includeAll": false
      },
      {
        "type": "query",
        "name": "env",
        "label": "Environment",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(up{job=~\"yb.*\"}, env)",
        "definition": "label_values(up{job=~\"yb.*\"}, env)",
        "refresh": 2,
        "sort": 1,
        "hide": 0,
        "multi": true,
        "includeAll": true,
        "current": {},
        "regex": "",
        "allValue": ".*"
      },
      {
        "type": "query",
        "name": "namespace",
        "label": "Namespace",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(up{job=~\"yb.*\",env=~\"$env\"}, namespace)",
        "definition": "label_values(up{job=~\"yb.*\",env=~\"$env\"}, namespace)",
        "refresh": 2,
        "sort": 1,
        "hide": 0,
        "multi": true,
        "includeAll": true,
        "current": {},
        "regex": "",
        "allValue": ".*"
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "type": "dashboard",
        "hide": true,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "name": "Annotations & Alerts",
        "iconColor": "rgba(0, 211, 255, 1)"
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Fleet health",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "type": "stat",
      "title": "Environments",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "count(count by (env)(up{job=\"yb-master\",env=~\"$env\",namespace=~\"$namespace\"}))",
          "legendFormat": "",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "id": 1
    },
    {
      "type": "stat",
      "title": "Namespaces with YB",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "count(count by (env,namespace)(up{env=~\"$env\",namespace=~\"$namespace\"}))",
          "legendFormat": "",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "id": 2
    },
    {
      "type": "stat",
      "title": "Masters Up",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(max by (env,namespace,pod)(up{job=\"yb-master\",env=~\"$env\",namespace=~\"$namespace\"}))",
          "legendFormat": "",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "id": 3
    },
    {
      "type": "stat",
      "title": "Masters Down",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(max by (env,namespace,pod)(up{job=\"yb-master\",env=~\"$env\",namespace=~\"$namespace\"}) == bool 0)",
          "legendFormat": "",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "id": 4
    },
    {
      "type": "stat",
      "title": "TServers Up",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(max by (env,namespace,pod)(up{job=\"yb-tserver\",env=~\"$env\",namespace=~\"$namespace\"}))",
          "legendFormat": "",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "id": 5
    },
    {
      "type": "stat",
      "title": "TServers Down",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(max by (env,namespace,pod)(up{job=\"yb-tserver\",env=~\"$env\",namespace=~\"$namespace\"}) == bool 0)",
          "legendFormat": "",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "id": 6
    },
    {
      "type": "row",
      "title": "Throughput across environments / namespaces",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "YSQL Ops/sec by namespace",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (env,namespace)(rate(handler_latency_yb_ysqlserver_SQLProcessor_SelectStmt_count{env=~\"$env\",namespace=~\"$namespace\"}[5m])+rate(handler_latency_yb_ysqlserver_SQLProcessor_InsertStmt_count{env=~\"$env\",namespace=~\"$namespace\"}[5m])+rate(handler_latency_yb_ysqlserver_SQLProcessor_UpdateStmt_count{env=~\"$env\",namespace=~\"$namespace\"}[5m])+rate(handler_latency_yb_ysqlserver_SQLProcessor_DeleteStmt_count{env=~\"$env\",namespace=~\"$namespace\"}[5m])+rate(handler_latency_yb_ysqlserver_SQLProcessor_OtherStmts_count{env=~\"$env\",namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "{{env}}/{{namespace}}",
          "instant": false,
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": { "mode": "none", "group": "A" },
            "axisLabel": ""
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "id": 11
    },
    {
      "type": "timeseries",
      "title": "TServer Read+Write Ops/sec by namespace",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (env,namespace)(rate(handler_latency_yb_tserver_TabletServerService_Read_count{job=\"yb-tserver\",env=~\"$env\",namespace=~\"$namespace\"}[5m])+rate(handler_latency_yb_tserver_TabletServerService_Write_count{job=\"yb-tserver\",env=~\"$env\",namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "{{env}}/{{namespace}}",
          "instant": false,
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": { "mode": "none", "group": "A" },
            "axisLabel": ""
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "id": 12
    },
    {
      "type": "timeseries",
      "title": "Avg YSQL Select latency by namespace",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (env,namespace)(rate(handler_latency_yb_ysqlserver_SQLProcessor_SelectStmt_sum{env=~\"$env\",namespace=~\"$namespace\"}[5m]))/clamp_min(sum by (env,namespace)(rate(handler_latency_yb_ysqlserver_SQLProcessor_SelectStmt_count{env=~\"$env\",namespace=~\"$namespace\"}[5m])),1)",
          "legendFormat": "{{env}}/{{namespace}}",
          "instant": false,
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "µs",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": { "mode": "none", "group": "A" },
            "axisLabel": ""
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "id": 13
    },
    {
      "type": "timeseries",
      "title": "Log error rate by namespace (master+tserver)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (env,namespace)(rate(glog_error_messages{env=~\"$env\",namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "{{env}}/{{namespace}}",
          "instant": false,
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": { "mode": "none", "group": "A" },
            "axisLabel": ""
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "id": 14
    },
    {
      "type": "row",
      "title": "Per env / namespace status",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "type": "table",
      "title": "YugabyteDB instances by env / namespace",
      "description": "One row per env+namespace running YugabyteDB. No vCluster layer.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 10 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (env,namespace)(max by (env,namespace,pod)(up{job=\"yb-master\",env=~\"$env\",namespace=~\"$namespace\"}))",
          "legendFormat": "Masters Up",
          "instant": true,
          "range": false,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (env,namespace)(max by (env,namespace,pod)(up{job=\"yb-tserver\",env=~\"$env\",namespace=~\"$namespace\"}))",
          "legendFormat": "TServers Up",
          "instant": true,
          "range": false,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (env,namespace)(num_tablet_servers_live{env=~\"$env\",namespace=~\"$namespace\"})",
          "legendFormat": "Live TServers",
          "instant": true,
          "range": false,
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (env,namespace)(num_tablet_servers_dead{env=~\"$env\",namespace=~\"$namespace\"})",
          "legendFormat": "Dead TServers",
          "instant": true,
          "range": false,
          "refId": "D"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "metric_id": true,
              "metric_type": true,
              "instance": true,
              "service": true,
              "container": true,
              "endpoint": true,
              "exported_instance": true,
              "cluster": true,
              "prometheus": true,
              "vcluster": true
            },
            "renameByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Dead TServers" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "red", "value": 1 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": { "showHeader": true, "cellHeight": "sm", "footer": { "show": false } },
      "id": 16
    }
  ]
}
