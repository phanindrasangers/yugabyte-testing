          "expr": "sum(max by (vcluster,env,namespace,pod)(up{job=\"yb-master\",vcluster=~\"$vcluster\",env=~\"$env\",namespace=~\"$namespace\",pod=~\"$pod\"}))",
          "legendFormat": "",
