{
  "uid": "yb-env-detail",
  "title": "YugabyteDB \u00b7 vCluster / Environment Detail",
  "tags": [
    "yugabytedb",
    "detail"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "",
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "label": "Data source",
        "query": "prometheus",
        "refresh": 1,
        "hide": 0,
        "current": {},
        "regex": "",
        "multi": false,
        "includeAll": false
      },
      {
        "type": "query",
        "name": "vcluster",
        "label": "vCluster",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(up{job=~\"yb.*\"}, vcluster)",
        "definition": "label_values(up{job=~\"yb.*\"}, vcluster)",
        "refresh": 2,
        "sort": 1,
        "hide": 0,
        "multi": false,
        "includeAll": true,
        "current": {},
        "regex": "",
        "allValue": ".*"
      },
      {
        "type": "query",
        "name": "env",
        "label": "Environment",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(up{job=~\"yb.*\",vcluster=~\"$vcluster\"}, env)",
        "definition": "label_values(up{job=~\"yb.*\",vcluster=~\"$vcluster\"}, env)",
        "refresh": 2,
        "sort": 1,
        "hide": 0,
        "multi": false,
        "includeAll": false,
        "current": {},
        "regex": ""
      },
      {
        "type": "query",
        "name": "namespace",
        "label": "Namespace",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(up{job=~\"yb.*\",vcluster=~\"$vcluster\",env=\"$env\"}, namespace)",
        "definition": "label_values(up{job=~\"yb.*\",vcluster=~\"$vcluster\",env=\"$env\"}, namespace)",
        "refresh": 2,
        "sort": 1,
        "hide": 0,
        "multi": true,
        "includeAll": true,
        "current": {},
        "regex": "",
        "allValue": ".*"
      },
      {
        "type": "query",
        "name": "pod",
        "label": "Pod",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(up{job=~\"yb.*\",vcluster=~\"$vcluster\",env=\"$env\",namespace=~\"$namespace\"}, pod)",
        "definition": "label_values(up{job=~\"yb.*\",vcluster=~\"$vcluster\",env=\"$env\",namespace=~\"$namespace\"}, pod)",
        "refresh": 2,
        "sort": 1,
        "hide": 0,
        "multi": true,
        "includeAll": true,
        "current": {},
        "regex": "",
        "allValue": ".*"
      }
    ]
