{
  "uid": "kubehealth-fleet",
  "title": "KubeHealth · Gateway Check Fleet",
  "tags": ["kubehealth", "health", "gateway"],
  "schemaVersion": 39,
  "version": 2,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {"from": "now-3h", "to": "now"},
  "timezone": "",
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "label": "Data source",
        "query": "prometheus",
        "refresh": 1,
        "hide": 0,
        "current": {},
        "multi": false,
        "includeAll": false
      },
      {
        "type": "query",
        "name": "vcluster",
        "label": "vCluster",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "query": "label_values(kuberhealthy_check{job=~\"kuberhealthy.*\"}, vcluster)",
        "definition": "label_values(kuberhealthy_check{job=~\"kuberhealthy.*\"}, vcluster)",
        "refresh": 2,
        "sort": 1,
        "hide": 0,
        "multi": true,
        "includeAll": true,
        "current": {},
        "allValue": ".*"
      }
    ]
  },
  "annotations": {"list": [{"builtIn": 1, "type": "dashboard", "hide": true, "datasource": {"type": "grafana", "uid": "-- Grafana --"}, "name": "Annotations & Alerts", "iconColor": "rgba(0,211,255,1)"}]},
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "Summary",
      "collapsed": false,
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1},
      "panels": []
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Total Checks",
      "gridPos": {"x": 0, "y": 1, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "none", "graphMode": "none"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "fixed", "fixedColor": "text"}}},
      "targets": [
        {
          "expr": "count(kuberhealthy_check{job=~\"kuberhealthy.*\",vcluster=~\"$vcluster\"})",
          "instant": true,
          "legendFormat": ""
        }
      ]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Passing",
      "gridPos": {"x": 6, "y": 1, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]},
          "color": {"mode": "thresholds"}
        }
      },
      "targets": [
        {
          "expr": "count(kuberhealthy_check{job=~\"kuberhealthy.*\",vcluster=~\"$vcluster\",status=\"1\"}) or vector(0)",
          "instant": true,
          "legendFormat": ""
        }
      ]
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Failing",
      "gridPos": {"x": 12, "y": 1, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]},
          "color": {"mode": "thresholds"}
        }
      },
      "targets": [
        {
          "expr": "count(kuberhealthy_check{job=~\"kuberhealthy.*\",vcluster=~\"$vcluster\",status=\"0\"}) or vector(0)",
          "instant": true,
          "legendFormat": ""
        }
      ]
    },
    {
      "type": "stat",
      "id": 5,
      "title": "Pass Rate",
      "gridPos": {"x": 18, "y": 1, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 80}, {"color": "green", "value": 100}]},
          "color": {"mode": "thresholds"}
        }
      },
      "targets": [
        {
          "expr": "100 * count(kuberhealthy_check{job=~\"kuberhealthy.*\",vcluster=~\"$vcluster\",status=\"1\"}) / count(kuberhealthy_check{job=~\"kuberhealthy.*\",vcluster=~\"$vcluster\"})",
          "instant": true,
          "legendFormat": ""
        }
      ]
    },
    {
      "type": "row",
      "id": 6,
      "title": "Check Status",
      "collapsed": false,
      "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1},
      "panels": []
    },
    {
      "type": "table",
      "id": 7,
      "title": "Gateway Health — All Checks",
      "gridPos": {"x": 0, "y": 6, "w": 24, "h": 12},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"sortBy": [{"displayName": "Status", "desc": false}]},
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "left", "displayMode": "auto"}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Status"},
            "properties": [
              {"id": "custom.displayMode", "value": "color-background"},
              {"id": "custom.width", "value": 90},
              {"id": "mappings", "value": [
                {
                  "type": "value",
                  "options": {
                    "0": {"text": "FAIL", "color": "red", "index": 0},
                    "1": {"text": "PASS", "color": "green", "index": 1}
                  }
                }
              ]},
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}},
              {"id": "color", "value": {"mode": "thresholds"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Error"},
            "properties": [
              {"id": "custom.width", "value": 500},
              {"id": "custom.displayMode", "value": "auto"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "vCluster"},
            "properties": [{"id": "custom.width", "value": 180}]
          },
          {
            "matcher": {"id": "byName", "options": "Check"},
            "properties": [{"id": "custom.width", "value": 200}]
          },
          {
            "matcher": {"id": "byName", "options": "Time"},
            "properties": [{"id": "custom.hidden", "value": true}]
          }
        ]
      },
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {"mode": "columns", "valueLabel": "Status"}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "vcluster": "vCluster",
              "check": "Check",
              "error": "Error",
              "Value": "Status"
            },
            "excludeByName": {
              "__name__": true,
              "container": true,
              "endpoint": true,
              "exported_namespace": true,
              "instance": true,
              "job": true,
              "namespace": true,
              "pod": true,
              "service": true,
              "env": true,
              "status": true
            },
            "indexByName": {
              "vcluster": 0,
              "check": 1,
              "Value": 2,
              "error": 3
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "kuberhealthy_check{job=~\"kuberhealthy.*\",vcluster=~\"$vcluster\"}",
          "instant": true,
          "legendFormat": "{{vcluster}}/{{check}}"
        }
      ]
    },
    {
      "type": "row",
      "id": 8,
      "title": "Trends",
      "collapsed": false,
      "gridPos": {"x": 0, "y": 18, "w": 24, "h": 1},
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 9,
      "title": "Pass Rate % by vCluster",
      "gridPos": {"x": 0, "y": 19, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 80}, {"color": "green", "value": 100}]},
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      },
      "targets": [
        {
          "expr": "100 * count by(vcluster)(kuberhealthy_check{job=~\"kuberhealthy.*\",vcluster=~\"$vcluster\",status=\"1\"}) / count by(vcluster)(kuberhealthy_check{job=~\"kuberhealthy.*\",vcluster=~\"$vcluster\"})",
          "legendFormat": "{{vcluster}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 10,
      "title": "Failing Checks Over Time",
      "gridPos": {"x": 12, "y": 19, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]},
          "color": {"mode": "fixed", "fixedColor": "red"}
        }
      },
      "targets": [
        {
          "expr": "count by(vcluster)(kuberhealthy_check{job=~\"kuberhealthy.*\",vcluster=~\"$vcluster\",status=\"0\"})",
          "legendFormat": "{{vcluster}}"
        }
      ]
    }
  ]
}
