        "label": "Environment",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(up{job=~\"yb.*\",vcluster=~\"$vcluster\"}, env)",
        "definition": "label_values(up{job=~\"yb.*\",vcluster=~\"$vcluster\"}, env)",
        "refresh": 2,
        "sort": 1,
        "hide": 0,
        "multi": true,
        "includeAll": true,
        "current": {},
        "regex": "",
        "allValue": ".*"
      },
      {
        "type": "query",
        "name": "namespace",
        "label": "Namespace",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(up{job=~\"yb.*\",vcluster=~\"$vcluster\",env=~\"$env\"}, namespace)",
        "definition": "label_values(up{job=~\"yb.*\",vcluster=~\"$vcluster\",env=~\"$env\"}, namespace)",
        "refresh": 2,
        "sort": 1,
        "hide": 0,
        "multi": true,
        "includeAll": true,
        "current": {},
        "regex": "",
        "allValue": ".*"
